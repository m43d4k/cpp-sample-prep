import {
    Button,
    CheckBox,
    ComboBox,
    HorizontalBox,
    LineEdit,
    ListView,
    Palette,
    ProgressIndicator,
    ScrollView,
    VerticalBox
} from "std-widgets.slint";

export struct TargetFileRow {
    selected: bool,
    source_path: string,
    input: string,
    input_path: string,
    status: string,
    info: string,
    output: string,
    output_path: string,
}

component TableCell inherits Rectangle {
    in property <string> text_value;
    in property <brush> text_color: Palette.foreground;
    in property <bool> is_header: false;

    background: transparent;
    clip: true;

    HorizontalLayout {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        padding-left: 8px;
        padding-right: 8px;
        padding-top: 4px;
        padding-bottom: 4px;
        spacing: 0px;

        Rectangle {
            background: transparent;

            Text {
                width: 100%;
                height: 100%;
                text: root.text_value;
                color: root.text_color;
                overflow: elide;
                vertical-alignment: center;
                font-weight: root.is_header ? 600 : 400;
            }
        }
    }
}

component SectionBox inherits VerticalBox {
    in property <length> content_padding: 6px;
    in property <bool> fill_height: false;

    vertical-stretch: root.fill_height ? 1 : 0;
    max-height: root.fill_height ? 100000px : self.min-height;

    Rectangle {
        border-radius: 6px;
        background: Palette.alternate-background;
        border-width: 1px;
        border-color: Palette.border;
        vertical-stretch: root.fill_height ? 1 : 0;

        VerticalBox {
            padding: root.content_padding;
            alignment: start;

            @children
        }
    }
}

export component MainWindow inherits Window {
    title: "SamplePrep";
    preferred-width: 920px;
    preferred-height: 640px;
    min-width: 760px;
    min-height: 560px;

    private property <string> default_prefix_affix: "converted_";
    private property <string> default_postfix_affix: "_converted";
    private property <length> page_padding: 6px;
    private property <length> group_padding: 6px;
    private property <length> section_spacing: 2px;
    private property <length> block_spacing: 8px;
    private property <length> label_spacing: 2px;
    private property <length> field_action_spacing: 8px;
    private property <length> input_table_spacing: 0px;
    private property <length> input_section_lead_spacing: 4px;
    private property <length> trailing_block_spacing: root.block_spacing - root.group_padding;
    private property <length> file_rule_row_height: 48px;
    private property <length> inline_spacing: 8px;
    private property <length> action_spacing: 6px;
    private property <length> control_row_height: 22px;
    private property <length> table_row_height: 34px;
    private property <length> about_dialog_width: 360px;
    private property <length> file_name_rule_width: 280px;
    private property <length> file_name_affix_width: 280px;
    private property <length> output_mode_checkbox_width: 220px;
    private property <length> checkbox_align_offset: 10px;
    private property <length> column_input_width: 110px;
    private property <length> column_input_path_width: 180px;
    private property <length> column_status_width: 180px;
    private property <length> column_info_width: 140px;
    private property <length> column_output_width: 110px;
    private property <length> table_fixed_width: root.column_input_width
        + root.column_input_path_width
        + root.column_status_width
        + root.column_info_width
        + root.column_output_width;
    private property <length> column_output_path_min_width: 140px;
    private property <bool> output_directory_locked: root.overwrite_originals || root.use_source_file_directory;
    private property <string> creator_name: "Warf ARCANA";
    private property <string> creator_url: "https://warfarcana.com/";

    in-out property <string> input_path;
    in-out property <bool> overwrite_originals;
    in-out property <bool> use_source_file_directory;
    in-out property <string> output_directory;
    in-out property <int> file_name_rule_index;
    in-out property <string> file_name_affix;
    in-out property <int> sample_rate_index;
    in-out property <int> output_format_index;
    in-out property <int> bit_depth_index;
    in-out property <int> cpu_core_count_index;
    in-out property <float> progress_value;
    in-out property <string> status_text;
    in-out property <bool> is_running;
    in-out property <bool> show_about_dialog;
    in-out property <string> app_version;
    in-out property <string> target_files_summary;
    in property <[TargetFileRow]> target_file_rows;
    in property <[string]> log_lines;

    callback request_run();
    callback request_refresh_input_preview();
    callback request_pick_input_files();
    callback request_pick_input_directory();
    callback request_pick_output_directory();
    callback request_open_url(string);
    callback set_target_file_selection(string, bool);
    callback set_all_target_file_selection(bool);

    ScrollView {
        width: 100%;
        height: 100%;

        VerticalBox {
            x: 0;
            y: 0;
            padding: root.page_padding;
            spacing: root.section_spacing;
            min-width: max(720px, root.width - root.page_padding * 2);

            SectionBox {
                content_padding: root.group_padding;
                VerticalBox {
                    spacing: 0px;
                    alignment: start;

                    if root.target_file_rows.length > 0 : VerticalBox {
                        padding-left: root.checkbox_align_offset;

                        Text {
                            text: root.target_files_summary + " Click a row to include or exclude it.";
                            color: #666666;
                        }
                    }

                    if root.target_file_rows.length > 0 : Rectangle {
                        width: 100%;
                        height: root.block_spacing;
                        background: transparent;
                    }

                    if root.target_file_rows.length == 0 : Rectangle {
                        width: 100%;
                        height: root.input_section_lead_spacing;
                        background: transparent;
                    }

                    Rectangle {
                        width: 100%;
                        height: root.control_row_height;
                        background: transparent;

                        HorizontalLayout {
                            x: 0;
                            y: 0;
                            width: parent.width;
                            height: parent.height;
                            padding-left: root.checkbox_align_offset;
                            spacing: root.action_spacing;

                            Button {
                                text: "Add files";
                                horizontal-stretch: 0;
                                enabled: !root.is_running;
                                min-height: root.control_row_height;
                                max-height: root.control_row_height;
                                clicked => {
                                    root.request_pick_input_files();
                                }
                            }

                            Button {
                                text: "Add directory";
                                horizontal-stretch: 0;
                                enabled: !root.is_running;
                                min-height: root.control_row_height;
                                max-height: root.control_row_height;
                                clicked => {
                                    root.request_pick_input_directory();
                                }
                            }

                            Button {
                                text: "Select All";
                                horizontal-stretch: 0;
                                enabled: !root.is_running;
                                min-height: root.control_row_height;
                                max-height: root.control_row_height;
                                clicked => {
                                    root.set_all_target_file_selection(true);
                                }
                            }

                            Button {
                                text: "Deselect All";
                                horizontal-stretch: 0;
                                enabled: !root.is_running;
                                min-height: root.control_row_height;
                                max-height: root.control_row_height;
                                clicked => {
                                    root.set_all_target_file_selection(false);
                                }
                            }

                            Button {
                                text: "Clear";
                                horizontal-stretch: 0;
                                enabled: !root.is_running && root.input_path != "";
                                min-height: root.control_row_height;
                                max-height: root.control_row_height;
                                clicked => {
                                    root.input_path = "";
                                    root.request_refresh_input_preview();
                                }
                            }

                            Rectangle {
                                background: transparent;
                            }

                            Button {
                                text: "About";
                                horizontal-stretch: 0;
                                enabled: !root.show_about_dialog;
                                min-height: root.control_row_height;
                                max-height: root.control_row_height;
                                clicked => {
                                    root.show_about_dialog = true;
                                }
                            }
                        }
                    }

                    Rectangle {
                        width: 100%;
                        height: root.input_table_spacing;
                        background: transparent;
                    }

                    VerticalBox {
                        spacing: root.block_spacing;
                        alignment: start;
                        padding-left: root.checkbox_align_offset;
                        padding-right: root.checkbox_align_offset;

                        Rectangle {
                            width: 100%;
                            height: root.table_row_height;
                            background: Palette.background;
                            border-width: 1px;
                            border-color: Palette.border;

                            HorizontalLayout {
                                x: 0;
                                y: 0;
                                width: parent.width;
                                height: parent.height;
                                spacing: 0px;

                                TableCell {
                                    text_value: "Input";
                                    width: root.column_input_width;
                                    height: parent.height;
                                    is_header: true;
                                }
                                TableCell {
                                    text_value: "Input path";
                                    width: root.column_input_path_width;
                                    height: parent.height;
                                    is_header: true;
                                }
                                TableCell {
                                    text_value: "Status";
                                    width: root.column_status_width;
                                    height: parent.height;
                                    is_header: true;
                                }
                                TableCell {
                                    text_value: "Info";
                                    width: root.column_info_width;
                                    height: parent.height;
                                    is_header: true;
                                }
                                TableCell {
                                    text_value: "Output";
                                    width: root.column_output_width;
                                    height: parent.height;
                                    is_header: true;
                                }
                                TableCell {
                                    text_value: "Output path";
                                    width: max(root.column_output_path_min_width, parent.width - root.table_fixed_width);
                                    height: parent.height;
                                    is_header: true;
                                }
                            }
                        }

                        ListView {
                            width: 100%;
                            min-height: 152px;
                            preferred-height: 192px;

                            for row in root.target_file_rows : Rectangle {
                                width: parent.width;
                                height: root.table_row_height;
                                border-width: 1px;
                                border-color: row.selected ? Palette.selection-background : Palette.border;
                                background: row.selected ? Palette.selection-background : Palette.alternate-background;

                                row-layout := HorizontalLayout {
                                    x: 0;
                                    y: 0;
                                    width: parent.width;
                                    height: parent.height;
                                    spacing: 0px;

                                    TableCell {
                                        text_value: row.input;
                                        width: root.column_input_width;
                                        height: parent.height;
                                        text_color: row.selected ? Palette.selection-foreground : Palette.foreground;
                                    }
                                    TableCell {
                                        text_value: row.input_path;
                                        width: root.column_input_path_width;
                                        height: parent.height;
                                        text_color: row.selected ? Palette.selection-foreground : Palette.foreground;
                                    }
                                    TableCell {
                                        text_value: row.status;
                                        width: root.column_status_width;
                                        height: parent.height;
                                        text_color: row.selected ? Palette.selection-foreground : Palette.foreground;
                                    }
                                    TableCell {
                                        text_value: row.info;
                                        width: root.column_info_width;
                                        height: parent.height;
                                        text_color: row.selected ? Palette.selection-foreground : Palette.foreground;
                                    }
                                    TableCell {
                                        text_value: row.output;
                                        width: root.column_output_width;
                                        height: parent.height;
                                        text_color: row.selected ? Palette.selection-foreground : Palette.foreground;
                                    }
                                    TableCell {
                                        text_value: row.output_path;
                                        width: max(root.column_output_path_min_width, parent.width - root.table_fixed_width);
                                        height: parent.height;
                                        text_color: row.selected ? Palette.selection-foreground : Palette.foreground;
                                    }
                                }

                                TouchArea {
                                    enabled: !root.is_running;
                                    clicked => {
                                        root.set_target_file_selection(row.source_path, !row.selected);
                                    }
                                }
                            }
                        }
                    }
                }
            }

            SectionBox {
                content_padding: root.group_padding;
                VerticalBox {
                    spacing: root.block_spacing;
                    alignment: start;

                    Rectangle {
                        width: 100%;
                        height: root.control_row_height;
                        background: transparent;

                        HorizontalLayout {
                            x: 0;
                            y: 0;
                            width: parent.width;
                            height: parent.height;
                            padding-left: root.checkbox_align_offset;
                            spacing: root.inline_spacing;

                            CheckBox {
                                width: root.output_mode_checkbox_width;
                                text: "Overwrite original files";
                                checked <=> root.overwrite_originals;
                                enabled: !root.is_running;
                                toggled => {
                                    if (root.overwrite_originals) {
                                        root.use_source_file_directory = false;
                                    }
                                    root.request_refresh_input_preview();
                                }
                            }

                            CheckBox {
                                width: root.output_mode_checkbox_width;
                                text: "Use source file directory";
                                checked <=> root.use_source_file_directory;
                                enabled: !root.is_running;
                                toggled => {
                                    if (root.use_source_file_directory) {
                                        root.overwrite_originals = false;
                                    }
                                    root.request_refresh_input_preview();
                                }
                            }
                        }
                    }

                    VerticalBox {
                        spacing: root.label_spacing;
                        alignment: start;

                        Text { text: "Output directory"; }
                        LineEdit {
                            text <=> root.output_directory;
                            enabled: !root.output_directory_locked && !root.is_running;
                            min-height: root.control_row_height;
                            max-height: root.control_row_height;
                            placeholder-text: "/path/to/output-directory";
                            edited(text) => {
                                root.request_refresh_input_preview();
                            }
                        }

                        Rectangle {
                            width: 100%;
                            height: root.field_action_spacing - root.label_spacing;
                            background: transparent;
                        }

                        Rectangle {
                            width: 100%;
                            height: root.control_row_height;
                            background: transparent;

                            HorizontalLayout {
                                x: 0;
                                y: 0;
                                width: parent.width;
                                height: parent.height;

                                Button {
                                    text: "Select Output";
                                    horizontal-stretch: 0;
                                    enabled: !root.output_directory_locked && !root.is_running;
                                    min-height: root.control_row_height;
                                    max-height: root.control_row_height;
                                    clicked => {
                                        root.request_pick_output_directory();
                                    }
                                }

                                Rectangle {
                                    background: transparent;
                                }
                            }
                        }
                    }

                    Rectangle {
                        width: 100%;
                        height: root.file_rule_row_height;
                        background: transparent;

                        HorizontalLayout {
                            x: 0;
                            y: 0;
                            width: parent.width;
                            height: parent.height;
                            spacing: root.inline_spacing;

                            VerticalBox {
                                width: root.file_name_rule_width;
                                spacing: root.label_spacing;

                                Text { text: "File name rule"; }
                                ComboBox {
                                    model: ["Prefix", "Postfix"];
                                    current-index <=> root.file_name_rule_index;
                                    enabled: !root.overwrite_originals && !root.is_running;
                                    min-height: root.control_row_height;
                                    max-height: root.control_row_height;
                                    selected => {
                                        if (root.file_name_affix == ""
                                            || root.file_name_affix == root.default_prefix_affix
                                            || root.file_name_affix == root.default_postfix_affix) {
                                            root.file_name_affix = self.current-index == 0
                                                ? root.default_prefix_affix
                                                : root.default_postfix_affix;
                                        }
                                        root.request_refresh_input_preview();
                                    }
                                }
                            }

                            VerticalBox {
                                width: root.file_name_affix_width;
                                spacing: root.label_spacing;

                                Text { text: "Prefix / postfix text"; }
                                LineEdit {
                                    text <=> root.file_name_affix;
                                    enabled: !root.overwrite_originals && !root.is_running;
                                    min-height: root.control_row_height;
                                    max-height: root.control_row_height;
                                    placeholder-text: root.file_name_rule_index == 0
                                        ? root.default_prefix_affix
                                        : root.default_postfix_affix;
                                    edited(text) => {
                                        root.request_refresh_input_preview();
                                    }
                                }
                            }
                        }
                    }

                    Rectangle {
                        width: 100%;
                        height: root.trailing_block_spacing;
                        background: transparent;
                    }
                }
            }

            SectionBox {
                content_padding: root.group_padding;
                HorizontalBox {
                    spacing: root.inline_spacing;
                    alignment: start;

                    VerticalBox {
                        spacing: root.label_spacing;
                        Text { text: "Sample rate"; }
                        ComboBox {
                            model: ["44100", "48000", "88200", "96000"];
                            current-index <=> root.sample_rate_index;
                            enabled: !root.is_running;
                            min-height: root.control_row_height;
                            max-height: root.control_row_height;
                        }
                    }

                    VerticalBox {
                        spacing: root.label_spacing;
                        Text { text: "Output format"; }
                        ComboBox {
                            model: ["wav", "aiff"];
                            current-index <=> root.output_format_index;
                            enabled: !root.is_running;
                            min-height: root.control_row_height;
                            max-height: root.control_row_height;
                            selected => {
                                root.request_refresh_input_preview();
                            }
                        }
                    }

                    VerticalBox {
                        spacing: root.label_spacing;
                        Text { text: "Bit depth"; }
                        ComboBox {
                            model: ["8 bit PCM", "16 bit PCM", "24 bit PCM", "32 bit PCM"];
                            current-index <=> root.bit_depth_index;
                            enabled: !root.is_running;
                            min-height: root.control_row_height;
                            max-height: root.control_row_height;
                        }
                    }

                    VerticalBox {
                        spacing: root.label_spacing;
                        Text { text: "Use CPU cores"; }
                        ComboBox {
                            model: ["All", "1", "2", "3", "4", "6", "8", "10"];
                            current-index <=> root.cpu_core_count_index;
                            enabled: !root.is_running;
                            min-height: root.control_row_height;
                            max-height: root.control_row_height;
                        }
                    }
                }
            }

            SectionBox {
                content_padding: root.group_padding;
                VerticalBox {
                    spacing: root.block_spacing;
                    alignment: start;

                    HorizontalBox {
                        spacing: root.inline_spacing;
                        alignment: start;

                        Button {
                            text: root.is_running ? "Running..." : "Convert";
                            primary: true;
                            enabled: !root.is_running;
                            min-height: root.control_row_height;
                            max-height: root.control_row_height;
                            clicked => {
                                root.request_run();
                            }
                        }

                        Text {
                            text: root.status_text;
                        }
                    }

                    ProgressIndicator {
                        progress: root.progress_value;
                    }
                }
            }

            SectionBox {
                content_padding: root.group_padding;
                fill_height: true;
                VerticalBox {
                    spacing: root.block_spacing;
                    alignment: start;

                    Text { text: "Log"; }

                    ListView {
                        min-height: 180px;
                        preferred-height: 220px;

                        for line in root.log_lines : Rectangle {
                            width: parent.width;
                            height: 24px;

                            Text {
                                width: parent.width;
                                height: parent.height;
                                text: line;
                                horizontal-alignment: left;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }

    if root.show_about_dialog : Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        background: #00000066;

        TouchArea {
            x: 0;
            y: 0;
            width: parent.width;
            height: parent.height;
            clicked => {
                root.show_about_dialog = false;
            }
        }

        Rectangle {
            width: min(root.about_dialog_width, parent.width - 32px);
            height: 190px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Palette.background;
            border-width: 1px;
            border-color: Palette.border;
            border-radius: 8px;

            VerticalBox {
                padding: 16px;
                spacing: 10px;
                alignment: start;

                Text {
                    text: "SamplePrep";
                    font-size: 18px;
                    font-weight: 600;
                }

                Text {
                    text: "Version: " + root.app_version;
                }

                Text {
                    text: "Created by: " + root.creator_name;
                }

                Rectangle {
                    background: transparent;
                    width: 100%;
                    height: creator-link.preferred-height;

                    creator-link := Text {
                        x: 0px;
                        y: 0px;
                        width: self.preferred-width;
                        text: root.creator_url;
                        horizontal-alignment: left;
                        color: creator-link-area.has-hover ? Palette.selection-background.brighter(0.2) : Palette.selection-background;
                    }

                    Rectangle {
                        x: creator-link.x;
                        y: creator-link.y + creator-link.preferred-height - 1px;
                        width: creator-link.preferred-width;
                        height: 1px;
                        background: creator-link.color;
                    }

                    creator-link-area := TouchArea {
                        x: 0px;
                        y: 0px;
                        width: creator-link.preferred-width;
                        height: creator-link.preferred-height;
                        mouse-cursor: pointer;
                        clicked => {
                            root.request_open_url(root.creator_url);
                        }
                    }
                }

                Rectangle {
                    background: transparent;
                }

                HorizontalLayout {
                    spacing: 0px;

                    Rectangle {
                        background: transparent;
                    }

                    Button {
                        text: "Close";
                        horizontal-stretch: 0;
                        clicked => {
                            root.show_about_dialog = false;
                        }
                    }
                }
            }
        }
    }
}
